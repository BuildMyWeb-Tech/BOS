generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  customDomain       String?             @unique
  businessType       String              @default("general")
  description        String              @default("")
  logo               String              @default("")
  email              String
  phone              String              @default("")
  address            String              @default("")
  website            String?
  status             TenantStatus        @default(PENDING)
  isActive           Boolean             @default(false)
  modules            Json                @default("{}")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  addresses          Address[]
  bills              Bill[]
  blockedDates       BlockedDate[]
  bookings           Booking[]
  carts              Cart[]
  coupons            Coupon[]
  customers          Customer[]
  inventory          Inventory[]
  notifications      Notification[]
  orders             Order[]
  products           Product[]
  productCategories  ProductCategory[]
  ratings            Rating[]
  recurringHolidays  RecurringHoliday[]
  resources          Resource[]
  roles              Role[]
  sales              Sale[]
  services           Service[]
  serviceCategories  ServiceCategory[]
  slotConfig         SlotConfig?
  specialWorkingDays SpecialWorkingDay[]
  staff              Staff[]
  storeSizes         StoreSize[]
  settings           TenantSettings?
  users              User[]
  wishlists          Wishlist[]

  @@index([slug])
  @@index([customDomain])
  @@index([status])
  @@index([isActive])
}

model User {
  id            String           @id @default(cuid())
  tenantId      String?
  name          String
  email         String
  phone         String?
  passwordHash  String
  image         String           @default("")
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  addresses     Address[]
  bills         Bill[]
  bookings      Booking[]        @relation("CustomerBookings")
  cart          Cart?
  customer      Customer?
  notifications Notification[]
  orders        Order[]
  ratings       Rating[]
  sales         Sale[]
  staff         Staff?
  tenant        Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles     UserRoleAssign[]
  wishlists     Wishlist[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([isActive])
}

model Role {
  id          String           @id @default(cuid())
  tenantId    String?
  name        String
  description String?          @default("")
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  assignments UserRoleAssign[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  module      String
  action      String
  description String           @default("")
  roles       RolePermission[]

  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model UserRoleAssign {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  tenantId   String
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([tenantId])
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String   @unique
  tags      String[] @default([])
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ServiceCategory {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String    @default("")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  services    Service[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Service {
  id              String           @id @default(cuid())
  tenantId        String
  categoryId      String?
  name            String
  description     String           @default("")
  duration        Int
  price           Float
  isActive        Boolean          @default(true)
  image           String           @default("")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bookingServices BookingService[]
  category        ServiceCategory? @relation(fields: [categoryId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
  @@index([tenantId])
  @@index([categoryId])
  @@index([isActive])
}

model Staff {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String    @unique
  bio        String?
  leaveDates String[]  @default([])
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  bookings   Booking[]
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([isActive])
}

model Resource {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  type        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  bookings    Booking[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
  @@index([tenantId])
}

model SlotConfig {
  id                     String   @id @default(cuid())
  tenantId               String   @unique
  slotStartTime          String   @default("09:00")
  slotEndTime            String   @default("17:00")
  slotDuration           Int      @default(30)
  breakEnabled           Boolean  @default(false)
  breakStartTime         String?
  breakEndTime           String?
  daysOpen               String[] @default([])
  maxAdvanceBookingDays  Int      @default(30)
  minBookingHoursBefore  Int      @default(2)
  allowRescheduling      Boolean  @default(true)
  rescheduleHoursBefore  Int      @default(24)
  advancePaymentRequired Boolean  @default(true)
  advancePaymentPercent  Int      @default(100)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model BlockedDate {
  id        String   @id @default(cuid())
  tenantId  String
  date      String
  reason    String?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
}

model RecurringHoliday {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  type      String
  value     String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SpecialWorkingDay {
  id        String   @id @default(cuid())
  tenantId  String
  date      String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
}

model Booking {
  id                 String           @id @default(cuid())
  tenantId           String
  customerId         String
  staffId            String?
  resourceId         String?
  date               String
  startTime          String
  endTime            String
  status             BookingStatus    @default(PENDING_PAYMENT)
  totalAmount        Float
  paidAmount         Float            @default(0)
  remainingAmount    Float            @default(0)
  paymentPercent     Int              @default(100)
  notes              String?
  cancellationReason String?
  cancelledBy        String?
  reminderSent       Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  customer           User             @relation("CustomerBookings", fields: [customerId], references: [id])
  resource           Resource?        @relation(fields: [resourceId], references: [id])
  staff              Staff?           @relation(fields: [staffId], references: [id])
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments           BookingPayment[]
  services           BookingService[]

  @@unique([tenantId, staffId, date, startTime])
  @@index([tenantId])
  @@index([customerId])
  @@index([date])
  @@index([status])
  @@index([tenantId, date])
}

model BookingService {
  id        String  @id @default(cuid())
  bookingId String
  serviceId String
  price     Float
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@index([serviceId])
}

model BookingPayment {
  id                String   @id @default(cuid())
  bookingId         String
  amount            Float
  method            String
  razorpayOrderId   String?
  razorpayPaymentId String?  @unique
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
}

model ProductCategory {
  id          String    @id @default(cuid())
  tenantId    String?
  name        String
  description String    @default("")
  image       String    @default("")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String    @default("ADMIN")
  products    Product[]
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
  @@index([tenantId])
}

model Product {
  id          String           @id @default(cuid())
  tenantId    String?
  name        String
  description String           @default("")
  mrp         Float            @default(0)
  images      String[]         @default([])
  categoryId  String?
  quantity    Int              @default(0)
  inStock     Boolean          @default(true)
  isDeleted   Boolean          @default(false)
  sku         String?
  keyFeatures String[]         @default([])
  createdBy   String           @default("TENANT")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  billItems   BillItem[]
  inventory   Inventory[]
  orderItems  OrderItem[]
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batches     ProductBatch[]
  variants    ProductVariant[]
  ratings     Rating[]
  wishlists   Wishlist[]

  @@index([tenantId])
  @@index([inStock])
  @@index([sku])
  @@index([isDeleted])
  @@index([tenantId, isDeleted])
}

model ProductVariant {
  id        String         @id @default(cuid())
  productId String
  size      String
  price     Float
  barcode   String?
  stock     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  billItems BillItem[]
  batches   ProductBatch[]
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([barcode])
  @@index([stock])
}

model ProductBatch {
  id           String          @id @default(cuid())
  productId    String
  variantId    String?
  batchNumber  String?
  expiryDate   DateTime?
  quantity     Int
  remainingQty Int
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  billItems    BillItem[]
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([variantId])
  @@index([expiryDate])
  @@index([remainingQty])
  @@index([productId, expiryDate])
  @@index([remainingQty, expiryDate])
  @@index([batchNumber])
}

model Inventory {
  id        String   @id @default(cuid())
  productId String
  tenantId  String
  quantity  Int      @default(0)
  lowStock  Int      @default(10)
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([productId, tenantId])
  @@index([tenantId])
  @@index([productId])
  @@index([quantity])
}

model Bill {
  id           String     @id @default(cuid())
  tenantId     String
  billNumber   String
  subtotal     Float
  discount     Float      @default(0)
  taxAmount    Float      @default(0)
  total        Float
  paymentMode  String     @default("CASH")
  note         String?
  paidAmount   Float?
  changeAmount Float?
  employeeId   String?
  createdAt    DateTime   @default(now())
  employee     User?      @relation(fields: [employeeId], references: [id])
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items        BillItem[]

  @@index([tenantId])
  @@index([createdAt])
  @@index([billNumber])
  @@index([tenantId, createdAt])
  @@index([employeeId])
}

model BillItem {
  id        String          @id @default(cuid())
  billId    String
  productId String
  variantId String?
  batchId   String?
  name      String
  size      String?
  price     Float
  quantity  Int
  discount  Float           @default(0)
  total     Float
  batch     ProductBatch?   @relation(fields: [batchId], references: [id])
  bill      Bill            @relation(fields: [billId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([billId])
  @@index([productId])
  @@index([variantId])
}

model Sale {
  id          String     @id @default(cuid())
  tenantId    String
  amount      Float
  source      SaleSource @default(ORDER)
  referenceId String
  employeeId  String?
  createdAt   DateTime   @default(now())
  employee    User?      @relation(fields: [employeeId], references: [id])
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([source])
  @@index([referenceId])
}

model Order {
  id            String          @id @default(cuid())
  tenantId      String
  userId        String
  addressId     String
  total         Float
  status        OrderStatus     @default(ORDER_PLACED)
  isPaid        Boolean         @default(false)
  paymentMethod PaymentMethod   @default(COD)
  isCouponUsed  Boolean         @default(false)
  coupon        Json            @default("{}")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  address       Address         @relation(fields: [addressId], references: [id])
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
  orderItems    OrderItem[]
  timeline      OrderTimeline[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}

model OrderTimeline {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  changedBy String
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model OrderItem {
  orderId   String
  productId String
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@id([orderId, productId])
  @@index([productId])
}

model Address {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  name      String
  email     String
  street    String
  city      String
  state     String
  zip       String
  country   String
  phone     String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
  @@index([tenantId])
}

model Cart {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String     @unique
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([tenantId])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
}

model Wishlist {
  id        String  @id @default(cuid())
  tenantId  String
  userId    String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, tenantId])
  @@index([userId, tenantId])
}

model Rating {
  id        String   @id @default(cuid())
  tenantId  String
  rating    Int
  review    String
  userId    String
  productId String
  orderId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, orderId])
  @@index([tenantId])
  @@index([productId])
}

model Coupon {
  id          String   @id @default(cuid())
  tenantId    String?
  code        String
  description String
  discount    Float
  forNewUser  Boolean  @default(false)
  forMember   Boolean  @default(false)
  isPublic    Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([expiresAt])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model TenantSettings {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  gstNumber       String?
  taxType         String   @default("SINGLE")
  taxPercent      Float    @default(18)
  cgst            Float    @default(9)
  sgst            Float    @default(9)
  currency        String   @default("INR")
  showStoreName   Boolean  @default(true)
  showGST         Boolean  @default(true)
  footerMessage   String?  @default("Thank you!")
  defaultLowStock Int      @default(10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model StoreSize {
  id        String   @id @default(cuid())
  tenantId  String
  label     String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, label])
  @@index([tenantId])
}

enum TenantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum SaleSource {
  ORDER
  BILLING
}

enum OrderStatus {
  ORDER_PLACED
  PROCESSING
  SHIPPED
  DELIVERED
  CONFIRMED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
}

enum PaymentMethod {
  COD
  RAZORPAY
  CASH
  UPI
  CARD
}
