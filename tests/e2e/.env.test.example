# tests/e2e/.env.test
# Copy this file to tests/e2e/.env.test and fill in your real values.
# This file is gitignored — never commit real passwords.
#
# How to get these values:
#   1. Run:  npm run db:seed
#   2. The seed script prints the super admin email + password it creates.
#   3. Register a vendor via /register, get it approved in /super-admin/vendors,
#      then use that vendor's email + password below.
#
# The tests will skip with a helpful message if this file is missing.

# Super Admin — created by npm run db:seed
E2E_SUPER_ADMIN_EMAIL=admin@yourbos.com
E2E_SUPER_ADMIN_PASSWORD=Admin@123456

# An approved vendor account in your DB
E2E_VENDOR_EMAIL=ajaikumar0811@gmail.com
E2E_VENDOR_PASSWORD=BOS@vmr6s1ci