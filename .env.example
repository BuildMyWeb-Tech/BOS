# ─────────────────────────────────────────────────────────────────
# BOS — Business Operating System
# Environment Variables — EXAMPLE FILE
#
# Copy this file to .env.local (development) or configure these as
# Environment Variables in your Vercel project settings (production).
# NEVER commit .env.local — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────

# ── APP ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME='BOS'
# Production: set to your actual deployed domain, e.g. https://yourbos.com
NEXT_PUBLIC_APP_URL='http://localhost:3000'
NEXT_PUBLIC_CURRENCY_SYMBOL='₹'

# ── DATABASE (Neon PostgreSQL) ────────────────────────────────────
# Get these from: https://console.neon.tech → Project → Connection Details
#
# DATABASE_URL : POOLED connection (has "-pooler" in the hostname).
#                Used for all normal application queries at runtime.
#                Required because serverless functions open many short-lived
#                connections — without pooling you will exhaust Postgres's
#                connection limit under load.
# DIRECT_URL   : DIRECT connection (no "-pooler" in the hostname).
#                Used only by Prisma Migrate / `prisma db push`, which
#                need a non-pooled connection to run schema changes safely.
DATABASE_URL='postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require'
DIRECT_URL='postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require&channel_binding=require'

# ── AUTHENTICATION ────────────────────────────────────────────────
# Generate a strong secret locally — never reuse this across environments:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET='replace-with-a-64-byte-random-hex-string'

# Super Admin bootstrap credentials — used ONLY by `npm run db:seed`.
# After the first seed, log in normally through the app; these are not
# read at runtime. Change the password immediately after first login.
SUPER_ADMIN_EMAIL='admin@yourbos.com'
SUPER_ADMIN_PASSWORD='choose-a-strong-temporary-password'
SUPER_ADMIN_NAME='Super Admin'

# ── IMAGE STORAGE (ImageKit) ──────────────────────────────────────
# Get these from: https://imagekit.io → Developer Options → API Keys
# Optional in early development — product/service images will simply
# have no upload destination until these are set.
IMAGEKIT_PUBLIC_KEY=''
IMAGEKIT_PRIVATE_KEY=''
IMAGEKIT_URL_ENDPOINT=''

# ── PAYMENTS (Razorpay) ───────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
# Required only once the Razorpay webhook/signature-verification phase
# is implemented (booking advance payments currently support cash/upi/
# card recording without a live gateway — see BookingPayment in schema).
RAZORPAY_KEY_ID=''
RAZORPAY_KEY_SECRET=''
NEXT_PUBLIC_RAZORPAY_KEY_ID=''

# ── BACKGROUND JOBS (Inngest) ─────────────────────────────────────
# Get these from: https://app.inngest.com → Your App → Keys
# Optional until background jobs (reminders, scheduled reports, etc.)
# are implemented.
INNGEST_EVENT_KEY=''
INNGEST_SIGNING_KEY=''

# ── MULTI-TENANT ROUTING ───────────────────────────────────────────
# Development: *.localhost resolves to 127.0.0.1 natively in Chrome/Firefox.
# middleware.ts reads the subdomain as the tenant slug.
#
# Examples:
#   http://acmesalon.localhost:3000   →  tenant slug = "acmesalon"
#   http://citygym.localhost:3000     →  tenant slug = "citygym"
#   http://localhost:3000             →  no tenant (super-admin / public pages)
#
# Production: middleware.ts checks Tenant.customDomain instead of subdomain.
#   Example: salonabc.com → DB lookup by customDomain → resolves tenant.
#   Vendors configure their custom domain in the BOS dashboard; you then
#   add that domain in Vercel's project settings and point its DNS at Vercel.
#
# Set to 'true' to let bare localhost (no subdomain) skip the tenant check —
# convenient for super-admin panel access during development. Should be
# unset or 'false' in production.
DEV_ALLOW_NO_TENANT='true'

# ── NODE ENVIRONMENT ────────────────────────────────────────────────
# Vercel sets this automatically (production/preview/development).
# No action needed unless running outside Vercel.
# NODE_ENV='development'
