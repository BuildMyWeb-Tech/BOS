# ─────────────────────────────────────────────────────────────────
# BOS — Business Operating System
# Environment Variables
#
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── APP ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME='BOS'
NEXT_PUBLIC_APP_URL='http://localhost:3000'
NEXT_PUBLIC_CURRENCY_SYMBOL='₹'

# ── DATABASE (Neon PostgreSQL) ────────────────────────────────────
# Get these from: https://console.neon.tech → Project → Connection Details
# DATABASE_URL  : pooled connection  (use for normal queries)
# DIRECT_URL    : direct connection  (use for Prisma migrations)
DATABASE_URL=''
DIRECT_URL=''

# ── AUTHENTICATION ────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=''

# Super Admin bootstrap credentials (used only by seed script)
# After seeding, log in normally — these are not used at runtime
SUPER_ADMIN_EMAIL='superadmin@bos.com'
SUPER_ADMIN_PASSWORD=''
SUPER_ADMIN_NAME='Super Admin'

# ── IMAGE STORAGE (ImageKit) ──────────────────────────────────────
# Get these from: https://imagekit.io → Developer Options
IMAGEKIT_PUBLIC_KEY=''
IMAGEKIT_PRIVATE_KEY=''
IMAGEKIT_URL_ENDPOINT=''

# ── PAYMENTS (Razorpay) ───────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=''
RAZORPAY_KEY_SECRET=''
NEXT_PUBLIC_RAZORPAY_KEY_ID=''

# ── BACKGROUND JOBS (Inngest) ─────────────────────────────────────
# Get these from: https://app.inngest.com → Your App → Keys
INNGEST_EVENT_KEY=''
INNGEST_SIGNING_KEY=''

# ── MULTI-TENANT DEVELOPMENT ──────────────────────────────────────
# Strategy: *.localhost resolves to 127.0.0.1 natively in Chrome/Firefox.
# In development, the middleware reads the subdomain as the tenant slug.
#
# Examples:
#   http://acmesalon.localhost:3000   →  tenant slug = "acmesalon"
#   http://citygym.localhost:3000     →  tenant slug = "citygym"
#   http://localhost:3000             →  no tenant (super-admin / public pages)
#
# In production, the middleware also checks Tenant.customDomain.
# Example: salonabc.com → DB lookup by customDomain → resolves to tenant
#
# Set to 'true' to allow localhost with no subdomain to skip tenant check
# (useful for super-admin panel access during development)
DEV_ALLOW_NO_TENANT='true'
